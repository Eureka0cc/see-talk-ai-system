AI_DASHSCOPE_API_KEY=sk-your-dashscope-api-key
# 也支持旧名 DASHSCOPE_API_KEY

# MySQL（本地开发需先创建 seetalk 库与用户，或使用 docker compose up mysql redis）
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=seetalk
MYSQL_USER=seetalk
MYSQL_PASSWORD=seetalk

# Snowflake ID（多实例部署时每个实例 worker-id 需不同，取值 0-31）
SEETALK_SNOWFLAKE_WORKER_ID=1
SEETALK_SNOWFLAKE_DATACENTER_ID=1

# Redis 热会话（最近 20 轮上下文 + 帧率限流）
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
